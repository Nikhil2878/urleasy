<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>URL Shortener</title>
  <link rel="stylesheet" href="/style.css" />
</head>
<body>

  <%- include('./partials/header.ejs') %>

  <main class="container">

    <% if(user){ %>
      <div class="alert success">
       Welcome, <strong><%= user.name %></strong>
      </div>
    <% } else { %>
      <div class="alert danger">
        ⚠ You are not logged in
      </div>
    <% } %>

    <div class="card">
      <h1>URL Shortener</h1>
      <p class="subtitle">Create short & shareable links instantly</p>

      <form action="/" method="post" class="url-form">
        <div class="input-group">
          <label>Enter URL</label>
          <input type="url" name="url" placeholder="https://example.com" required />
        </div>

        <div class="input-group">
          <label>Short Code</label>
          <input type="text" name="shortCode" placeholder="my-link" required />
        </div>
<% if(errors && errors.length > 0) { %> <%
      errors.forEach((error) => { %>
        <p style="color: red"><%- error %></p>
      <%})%> <% } %>
        <button type="submit">Shorten URL</button>
      </form>
    </div>

    <div class="card">
      <h2>📌 Your Shortened Links</h2>

      <% if(links.length === 0){ %>
        <p class="empty">No links created yet.</p>
      <% } %>

      <ul class="link-list">
        <% links.map(({ shortCode, url, id }) => { 
          const truncatedUrl = url.length > 35 ? url.slice(0,35) + '...' : url;
        %>
          <li class="link-item">
            <div class="link-info">
              <a href="/<%= shortCode %>" target="_blank" class="short-link">
                <%= host %>/<%= shortCode %>
              </a>
              <span class="original-url"><%= truncatedUrl %></span>
            </div>
            <div class="url-actions">  
  <!-- Edit -->
  <a href="/edit/<%= id %>" class="icon-btn edit-btn" title="Edit">
    <i class="zmdi zmdi-edit"></i>
  </a>

  <!-- Delete -->
  <form action="/delete/<%= id %>" method="post">
    <button class="icon-btn delete-btn" title="Delete">
      <i class="zmdi zmdi-delete"></i>
    </button>
  </form>

  <!-- Copy -->
  <button 
    class="icon-btn copy-btn" 
    title="Copy"
    onclick="copyLink('<%= host %>/<%= shortCode %>')"
  >
    <i class="zmdi zmdi-copy"></i>
  </button>

</div>
          </li>
        <% }) %>
      </ul>
    </div>

  </main>

  <div id="toast">Copied to clipboard!</div>

  
      <%# Pagination component %>
      <% if (totalPages > 1) { %>
           <div class="pagination">
             <%# Previous page link %>
             <% if (currentPage > 1) { %>
               <a href="?page=<%= currentPage - 1 %>" class="page-link">&laquo; Previous</a>
             <% } else { %>
               <span class="page-link disabled">&laquo; Previous</span>
             <% } %>

          

                   <%# Page numbers %>
          <% 
             // Calculate the range of page numbers to display
             let startPage = Math.max(1, currentPage - 2);
             let endPage = Math.min(totalPages, currentPage + 2);

                         // Ensure 5 pages are shown if possible
while (endPage - startPage < 4 && startPage > 1) {
  startPage--;
}
while (endPage - startPage < 4 && endPage < totalPages) {
  endPage++;
}

           %>
<% 
                 // Always show first pge
            if (startPage > 1) { %>
               <a href="?page=1" class="page-link">1</a>
               <% if (startPage > 2) { %>
                 <span class="ellipsis">...</span>
               <% } %>
             <% } %>
        
               <%# Show page numbers around current page %>
             <% for (let i = startPage; i <= endPage; i++) { %>
               <% if (i === currentPage) { %>
                 <span class="page-link current"><%= i %></span>
               <% } else { %>
                 <a href="?page=<%= i %>" class="page-link"><%= i %></a>
               <% } %>
             <% } %>
 
                     <%# Always show last page %>
             <% if (endPage < totalPages) { %>
               <% if (endPage < totalPages - 1) { %>
                 <span class="ellipsis">...</span>
               <% } %>
               <a href="?page=<%= totalPages %>" class="page-link"><%= totalPages %></a>
             <% } %>
                      
  
             <%# Next page link %>
             <% if (currentPage < totalPages) { %>
               <a href="?page=<%= currentPage + 1 %>" class="page-link">Next &raquo;</a>
             <% } else { %>
               <span class="page-link disabled">Next &raquo;</span>
             <% } %>

           </div>
         <% } %>

  <%- include('./partials/footer.ejs') %>
